<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Info</title>
</head>
<body>
  <h3>Information available for editing</h3>

  <form action="/comments/<%= each_comment.id %>?_method=PATCH" method="POST">

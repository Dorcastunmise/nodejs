<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>User Information</title>
</head>
<body>
  <h1> Data requested:</h1>
  <div>
    <h5><%= each_comment.username %>: <%= each_comment.comments %></h5>

    <br><br>
    <a href="/comments">Display all records</a>
    <a href="/comments/new">Create a new record</a>
    <a href="/comments/<%= each_comment.id %>/edit">Edit record</a>
    <form action="/comments/<%= each_comment.id %>?_method=DELETE" method="post">
      <button>Delete record</button> 
    </form>
  </div>
  
</body>
</html>